# =====================================================
# ID Generator Deployment Environment Variables
# Copy this file to .env and modify as needed
# =====================================================

# Shared PostgreSQL Configuration
DB_HOST=shared-postgres
DB_PORT=5432
DB_NAME=id_generator
DB_USER=postgres
DB_PASSWORD=postgres123456

# ID Generator Server Configuration
SERVER_PORT=8011
DATACENTER_ID=0
WORKER_ID=-1
SPRING_PROFILES_ACTIVE=docker

# Java Options
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC

# Clock Backwards Configuration
CLOCK_BACKWARDS_MAX_WAIT=5
CLOCK_BACKWARDS_ALERT_THRESHOLD=10

# Snowflake Epoch (2025-01-01 00:00:00 UTC)
SNOWFLAKE_EPOCH=1735689600000
