# =====================================================
# ID Generator Deployment Environment Variables
# Copy this file to .env and modify as needed
# =====================================================

# PostgreSQL Configuration
POSTGRES_DB=id_generator
POSTGRES_USER=id_gen_user
POSTGRES_PASSWORD=id_gen_password
POSTGRES_PORT=5436

# ZooKeeper Configuration
ZOOKEEPER_PORT=2182
ZOOKEEPER_ADMIN_PORT=8889

# ID Generator Server Configuration
SERVER_PORT=8010
DATACENTER_ID=0
WORKER_ID=-1
ENABLE_ZOOKEEPER=true
SPRING_PROFILES_ACTIVE=docker

# Java Options
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC

# Clock Backwards Configuration
CLOCK_BACKWARDS_MAX_WAIT=5
CLOCK_BACKWARDS_STARTUP_CHECK=true
CLOCK_BACKWARDS_ZK_SYNC_INTERVAL=3000
CLOCK_BACKWARDS_ALERT_THRESHOLD=10

# Snowflake Epoch (2025-01-01 00:00:00 UTC)
SNOWFLAKE_EPOCH=1735689600000
